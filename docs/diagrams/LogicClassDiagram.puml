@startuml
!include style.puml
skinparam arrowThickness 1.1
skinparam arrowColor LOGIC_COLOR_T4
skinparam classBackgroundColor LOGIC_COLOR

package Logic as LogicPackage {

package "Parser Classes" as ParserClasses{
}
Class XYZCommand
Class CommandResult
Class "{abstract}\nCommand" as Command


Class "<<interface>>\nLogic" as Logic
Class LogicManager
}

package Model {
Class HiddenModel #FFFFFF
}

package Storage {
}

Class HiddenOutside #FFFFFF
HiddenOutside ..> Logic

LogicManager ..up|> Logic
LogicManager -> "1 " ParserClasses
ParserClasses .down> XYZCommand : <<create>>

XYZCommand -down|> Command
LogicManager ..> Command : <<call>>

LogicManager ---up> Model
LogicManager -left> Storage
Logic -[hidden]> Model
Storage --[hidden]> Model
Command .> Model
note right of XYZCommand: XYZCommand =\n AddCommand, FindCommand, etc

Logic ..> CommandResult
LogicManager .down...> CommandResult
Command ....> CommandResult : <<create>>
@enduml
